# Variáveis para o backend (local ou Render)
# No Render: configure em Dashboard → Environment

NODE_ENV=production
PORT=3001

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# CORS — app mobile não envia Origin; necessário só para Expo web
ALLOWED_ORIGINS=http://localhost:8081

# Render injeta automaticamente (não precisa definir manualmente):
# PORT
